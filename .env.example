# Bot token (OAuth & Permissions page, after installing the app) - starts with xoxb-
SLACK_BOT_TOKEN=xoxb-...

# App-level token (Basic Information > App-Level Tokens, scope: connections:write) - starts with xapp-
SLACK_APP_TOKEN=xapp-...

# Comma-separated channel IDs the agent is allowed to search and respond in.
# Right-click a channel > View channel details > bottom of the About tab shows the ID (starts with C).
ALLOWED_CHANNEL_IDS=

# Channel the "Escalate to supervisor" button alerts in real time (e.g. #crisis-resources).
ESCALATION_CHANNEL_ID=

# ISO country code used for helpline lookups when the volunteer doesn't specify one.
DEFAULT_COUNTRY=IN

# Set to true to log full event payloads while debugging.
DEBUG_EVENTS=false
